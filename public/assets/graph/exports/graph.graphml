      <data key="d1">occupation</data>
      <data key="d2">25-1065.00</data>
      <data key="d3">Teach courses in political science, international affairs, and international relations. Includes both teachers primarily engaged in teaching and those who do a combination of teaching and research.</data>
      <data key="d4">onet</data>
    </node>
    <node id="occ:25-1066.00">
      <data key="d0">Psychology Teachers, Postsecondary</data>
      <data key="d1">occupation</data>
      <data key="d2">25-1066.00</data>
      <data key="d3">Teach courses in psychology, such as child, clinical, and developmental psychology, and psychological counseling. Includes both teachers primarily engaged in teaching and those who do a combination of teaching and research.</data>
      <data key="d4">onet</data>
    </node>
    <node id="occ:25-1067.00">

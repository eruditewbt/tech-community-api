      <data key="d1">occupation</data>
      <data key="d2">25-1082.00</data>
      <data key="d3">Teach courses in library science. Includes both teachers primarily engaged in teaching and those who do a combination of teaching and research.</data>
      <data key="d4">onet</data>
    </node>
